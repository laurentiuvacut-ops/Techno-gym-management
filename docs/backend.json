{
  "entities": {
    "Member": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Member",
      "type": "object",
      "description": "Represents a gym member.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string" },
        "qrCode": { "type": "string" },
        "expirationDate": { "type": "string", "format": "date" },
        "subscriptionType": { "type": "string" },
        "status": { "type": "string" },
        "agreedToTermsAt": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean", "description": "Computed client-side based on phone number for safety." }
      },
      "required": ["id", "name", "phone"]
    },
    "SharedWorkout": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SharedWorkout",
      "type": "object",
      "description": "A workout or bundle of workouts shared with the community.",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "creatorName": { "type": "string" },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "object" },
        "isOfficial": { "type": "boolean", "description": "True if created by the main admin Laurentiu." },
        "workouts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "duration": { "type": "number" },
              "exercises": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "videoUrl": { "type": "string" },
                    "imageUrl": { "type": "string" },
                    "sets": { "type": "array" }
                  }
                }
              }
            }
          }
        }
      },
      "required": ["title", "creatorName", "creatorId", "workouts"]
    }
  },
  "auth": {
    "providers": ["phone"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/members/{phoneNumber}",
        "definition": {
          "entityName": "Member",
          "schema": { "$ref": "#/backend/entities/Member" },
          "description": "User profile data."
        }
      },
      {
        "path": "/sharedWorkouts/{sharedId}",
        "definition": {
          "entityName": "SharedWorkout",
          "schema": { "$ref": "#/backend/entities/SharedWorkout" },
          "description": "Public workouts including official ones from Laurentiu."
        }
      }
    ]
  }
}