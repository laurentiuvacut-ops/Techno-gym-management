rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funcție helper pentru a verifica dacă utilizatorul este administratorul principal
    function isAdmin() {
      return request.auth != null && request.auth.token.phone_number == '+40753030493';
    }

    match /members/{phoneNumber} {
      allow read: if request.auth != null && request.auth.token.phone_number == phoneNumber;
      
      allow create: if request.auth != null && 
                       request.auth.token.phone_number == phoneNumber &&
                       request.resource.data.id == request.auth.uid;

      // Câmpurile sensibile (expirationDate, subscriptionType, status, isAdmin) 
      // sunt acum actualizate DOAR prin Webhook-ul Stripe sau manual în consolă.
      // Am scos 'isAdmin' din lista de câmpuri ce pot fi modificate de utilizator.
      allow update: if request.auth != null && 
                       request.auth.token.phone_number == phoneNumber &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['id', 'name', 'email', 'phone', 'photoURL', 'qrCode', 'agreedToTermsAt']);
      
      allow list, delete: if false;

      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.token.phone_number == phoneNumber;
      }
    }

    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /workouts/{workoutId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /trainers/{trainerId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow get, list: if isAdmin(); // Doar adminul poate vedea feedback-ul
      allow update, delete: if false;
    }

    match /sharedWorkouts/{sharedId} {
      allow get, list: if request.auth != null;
      
      // Doar adminul poate crea antrenamente marcate ca 'isOfficial'
      allow create: if request.auth != null && (
        request.resource.data.isOfficial == false || isAdmin()
      );
      
      allow delete: if request.auth != null && (
        resource.data.creatorId == request.auth.uid || isAdmin()
      );
      
      allow update: if false;
    }
  }
}