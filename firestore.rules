
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /members/{phoneNumber} {
      allow read: if request.auth != null && request.auth.token.phone_number == phoneNumber;
      
      allow create: if request.auth != null && 
                       request.auth.token.phone_number == phoneNumber &&
                       request.resource.data.id == request.auth.uid;

      // Câmpurile sensibile (expirationDate, subscriptionType, status) 
      // sunt acum actualizate DOAR prin Webhook-ul Stripe (Server-Side)
      allow update: if request.auth != null && 
                       request.auth.token.phone_number == phoneNumber &&
                       request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['id', 'name', 'email', 'phone', 'photoURL', 'qrCode', 'agreedToTermsAt', 'isAdmin']);
      
      allow list, delete: if false;

      // Permite accesul la orice subcolecție (measurements, checkins, workoutLogs, etc.)
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.token.phone_number == phoneNumber;
      }
    }

    match /subscriptions/{subscriptionId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /workouts/{workoutId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /trainers/{trainerId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow get, list: if request.auth != null;
      allow update, delete: if false;
    }

    match /sharedWorkouts/{sharedId} {
      // Refreshing rules to fix list permissions
      allow get, list: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && resource.data.creatorId == request.auth.uid;
      allow update: if false;
    }
  }
}
